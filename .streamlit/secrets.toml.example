# Cole isto em Streamlit Cloud > App > Settings > Secrets
# Troque as senhas antes de publicar.

[database]
# Neon normalmente entrega algo começando com postgresql:// ou postgres://
# Exemplo fictício:
url = "postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require"

[users.socio1]
password = "trocar-senha-socio-1"
role = "partner"
name = "Sócio 1"

[users.socio2]
password = "trocar-senha-socio-2"
role = "partner"
name = "Sócio 2"

[users.sdr]
password = "trocar-senha-sdr"
role = "sdr"
name = "SDR"
